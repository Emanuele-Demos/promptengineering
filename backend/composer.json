{
  "name": "winecellar/backend",
  "description": "WineCellar AI REST API",
  "type": "project",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "tymon/jwt-auth": "^2.2",
    "league/flysystem-aws-s3-v3": "^3.0",
    "predis/predis": "^2.2",
    "zircote/swagger-php": "^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "openapi": "php vendor/bin/openapi app -o ../docs/openapi.generated.json"
  }
}
